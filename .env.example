DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jinzai_ai?schema=public"
# SQLiteで動かしたい場合は prisma/schema.prisma の provider を "sqlite" に変更し以下を有効化
# DATABASE_URL="file:./dev.db"
AUTH_SECRET="dev-secret-change-me"

# Gemini API（AI入力代行・文書抽出・チャットに使用）
# 取得: https://aistudio.google.com/app/apikey
# 未設定時は抽出・チャット機能がモックレスポンスを返します
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
